{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agentenv Configuration",
  "description": "Configuration schema for agentenv (.agentrc.yaml)",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Configuration version"
    },
    "use_claude_config": {
      "type": "boolean",
      "default": false,
      "description": "Import marketplaces, plugins, and hooks from Claude Code's settings.json files (project ./.claude/settings.json and global ~/.claude/settings.json). When true, the `claude-code` target is dropped from sync because Claude Code is treated as the source of truth, not a destination."
    },
    "marketplaces": {
      "type": "object",
      "description": "Marketplaces by namespace. Required unless use_claude_config is true and Claude's settings.json provides extraKnownMarketplaces.",
      "additionalProperties": {
        "type": "object",
        "required": ["path", "remote"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "description": "Local path to marketplace cache"
          },
          "remote": {
            "type": "string",
            "format": "uri",
            "description": "Remote Git URL for marketplace"
          },
          "ref": {
            "type": "string",
            "description": "Git reference (branch/tag)",
            "default": "main"
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "description": "Plugins to import from marketplace",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Plugin name"
          },
          "namespace": {
            "type": "string",
            "description": "Marketplace namespace (defaults to 'default')"
          },
          "version": {
            "type": "string",
            "description": "Plugin version (defaults to latest)"
          }
        }
      }
    },
    "targets": {
      "type": "object",
      "description": "Target tools and their configurations",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "description": "Target type identifier (free-form; built-in defaults match the target name)."
          },
          "tools": {
            "type": "array",
            "description": "Specific tools this target applies to.",
            "items": { "type": "string" }
          },
          "paths": {
            "type": "object",
            "description": "Key paths for this target",
            "additionalProperties": {
              "type": "string"
            }
          },
          "source_mappings": {
            "type": "object",
            "description": "Per-capability install destinations (skills, commands, agents, etc.). The source is implicit: each plugin contributes <plugin_location>/<capability>.",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["target"],
                "additionalProperties": false,
                "properties": {
                  "target": {
                    "type": "string",
                    "description": "Destination directory under the target tool. Use {plugin} to expand the plugin name (e.g. .claude-code/{plugin}/skills). Without {plugin}, all plugins write to the same path and the last sync wins."
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["symlink", "copy"],
                    "default": "symlink",
                    "description": "How to install (symlink or copy)"
                  }
                }
              }
            }
          }
        }
      }
    },
    "sync": {
      "type": "object",
      "description": "Sync behavior configuration",
      "additionalProperties": false,
      "properties": {
        "onOpen": {
          "type": "boolean",
          "default": true,
          "description": "Run sync when editor opens"
        },
        "refetch": {
          "type": "boolean",
          "default": false,
          "description": "Re-fetch marketplace on sync"
        },
        "mode": {
          "type": "string",
          "enum": ["symlink", "copy"],
          "default": "symlink",
          "description": "Default installation mode"
        }
      }
    }
  }
}
